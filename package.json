{
  "name": "@aohys/development-system",
  "version": "0.7.0",
  "private": true,
  "description": "Canonical, installable, and reversible AOHYS development contract.",
  "type": "module",
  "bin": {
    "aohys-development-system": "./bin/development-system"
  },
  "scripts": {
    "audit": "./bin/development-system audit",
    "benchmark": "node ./scripts/run-benchmarks.mjs",
    "install:local": "./bin/development-system install --version 0.7.0",
    "harnesses:validate": "node ./scripts/validate-harnesses.mjs",
    "rollout:validate": "node ./scripts/validate-pilot-rollout.mjs",
    "implement-preview": "./bin/development-system implement-preview",
    "skills:audit": "./bin/development-system audit-skills --version 0.2.0 --evidence evidence/skills-live-2026-07-20.json",
    "skills:probe": "node ./scripts/probe-harness-skills.mjs",
    "skills:sync": "./bin/development-system sync-skills --version 0.2.0",
    "smoke:repositories": "node ./scripts/smoke-repository-audits.mjs",
    "scenario": "node ./scripts/reproduce-installation.mjs && node ./scripts/reproduce-skills.mjs && node ./scripts/reproduce-lifecycle.mjs && node ./scripts/reproduce-repository-preparation.mjs && node --test test/harness-scenario.test.mjs test/benchmark-scenario.test.mjs test/delivery-preview.test.mjs",
    "test": "node --test test/*.test.mjs",
    "test:acceptance": "node --test test/installation-scenario.test.mjs test/lifecycle-scenario.test.mjs",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "validate:global": "python3 ./scripts/validate-development-system.py --repos-root ..",
    "validate:repository": "./bin/development-system validate-repository",
    "verify": "pnpm run typecheck && pnpm run test && pnpm run validate:repository && pnpm run rollout:validate"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.7.0",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
