#!/bin/sh

set -eu

case "$0" in
  */*) script_directory=${0%/*} ;;
  *) script_directory=. ;;
esac
script_directory=$(CDPATH= cd -- "$script_directory" && pwd)

node_runtime=${AOHYS_NODE:-}
if [ -n "$node_runtime" ]; then
  if [ ! -x "$node_runtime" ]; then
    echo "Development System preflight: AOHYS_NODE is not an executable Node.js runtime: $node_runtime" >&2
    exit 127
  fi
elif command -v node >/dev/null 2>&1; then
  node_runtime=$(command -v node)
elif command -v nodejs >/dev/null 2>&1; then
  node_runtime=$(command -v nodejs)
else
  echo "Development System preflight: Node.js 22 or newer was not found. Install Node.js or set AOHYS_NODE to an executable runtime." >&2
  exit 127
fi

node_major=$($node_runtime -p "Number(process.versions.node.split('.')[0])" 2>/dev/null || true)
case "$node_major" in
  ''|*[!0-9]*)
    echo "Development System preflight: the selected runtime is not a working Node.js executable: $node_runtime" >&2
    exit 127
    ;;
esac
if [ "$node_major" -lt 22 ]; then
  echo "Development System preflight: Node.js 22 or newer is required; $node_runtime reports major version $node_major." >&2
  exit 127
fi

exec "$node_runtime" "$script_directory/development-system.mjs" "$@"
